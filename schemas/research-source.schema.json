{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchSource",
  "type": "object",
  "required": ["id", "title", "url"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "url": { "type": "string" },
    "date": { "type": "string" },
    "type": { "type": "string" },
    "credibility": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "notes": { "type": "string" }
  }
}
